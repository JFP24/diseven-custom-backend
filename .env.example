# ===== Configuración del servidor =====
PORT=3000
NODE_ENV=development

# ===== Base de datos (MongoDB Atlas) =====
# Reemplaza usuario, contraseña y nombre de la BD por los tuyos.
MONGODB_URI=mongodb+srv://USUARIO:CONTRASENA@cluster.mongodb.net/nombre_db

# ===== Autenticación (JWT) =====
# Genera uno con: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=pon_aqui_un_secreto_largo_y_aleatorio
JWT_EXPIRES_IN=7d

# ===== CORS =====
# Origen permitido del frontend. Usa coma para varios. "*" permite todos (solo dev).
CORS_ORIGIN=http://localhost:5173,http://localhost:5174
